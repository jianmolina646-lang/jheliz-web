# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,ecormecejhelizstore.com,www.ecormecejhelizstore.com

# Base URL
SITE_URL=http://127.0.0.1:8000

# Database (SQLite for local dev, Postgres for prod)
DATABASE_URL=sqlite:///db.sqlite3

# Email (use console backend in dev, SMTP en prod)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Para producción con SMTP (ej. Brevo/SendGrid/Hostinger):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Jheliz <no-reply@ecormecejhelizstore.com>
SUPPORT_ADMIN_EMAIL=admin@ecormecejhelizstore.com

# Mercado Pago (Perú)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# Web Push (PWA notifications). Generá las claves con:
#   python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); v.save_key('vapid_private.pem'); print('PUBLIC:', v.public_key.hex())"
# La pública se publica en /cuenta/push/config/ para que el navegador la use.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:soporte@ecormecejhelizstore.com

# Contact / Social
WHATSAPP_NUMBER=+51999999999
TELEGRAM_USERNAME=jhelizbot

# Bot de Telegram (opcional)
# Token desde @BotFather (/newbot)
TELEGRAM_BOT_TOKEN=
# Tu chat_id numérico para recibir notificaciones de pedidos nuevos
# (obtenlo con @userinfobot en Telegram)
TELEGRAM_ADMIN_CHAT_ID=
# Token random para validar el webhook de Telegram (path + header).
# Genéralo con: python -c 'import secrets;print(secrets.token_urlsafe(32))'
TELEGRAM_WEBHOOK_SECRET=
# Canal público de DISTRIBUIDORES (precios mayoristas, alertas técnicas).
# Puede ser @username o un ID numérico. Vacío = desactivado.
TELEGRAM_CHANNEL_ID=
# Canal público de CLIENTES FINALES (precios cliente, promos, restocks).
# Puede ser @username o un ID numérico. Vacío = desactivado.
TELEGRAM_CUSTOMER_CHANNEL_ID=

# ---------------------------------------------------------------------------
# Seguridad
# ---------------------------------------------------------------------------
# Cifrado de credenciales entregadas (Fernet). Generar UNA vez con:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# y guardarla en un gestor de secretos. Si la pierdes, NO podrás descifrar
# las credenciales ya guardadas.
FIELD_ENCRYPTION_KEY=

# django-axes: cuántos intentos fallidos antes de bloquear (por IP+usuario)
# y cuántas horas dura el bloqueo. Defaults endurecidos: 3 intentos / 24h.
AXES_FAILURE_LIMIT=3
AXES_COOLOFF_TIME_HOURS=24

# Notificaciones cuando alguien inicia sesión en el admin (email + Telegram).
# Se envían a SUPPORT_ADMIN_EMAIL y al TELEGRAM_ADMIN_CHAT_ID.
ADMIN_LOGIN_NOTIFY=True

# 2FA en el admin. Déjalo en False hasta que registres tu dispositivo TOTP
# en /panel-jheliz-2026/otp_totp/totpdevice/. Activarlo bloquea el admin a quien
# no tenga 2FA confirmado.
ADMIN_2FA_ENFORCED=False
